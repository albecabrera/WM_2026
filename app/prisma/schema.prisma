generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  name      String
  classCode String   // color class code, e.g. "gelb", "rot"
  loginCode String   @unique // e.g. "rasenrakete-gelb"
  role      String   @default("STUDENT")
  createdAt DateTime @default(now())

  tips              Tip[]
  tournamentWinnerTip TournamentWinnerTip?

  @@index([classCode])
}

model Class {
  id        String   @id @default(cuid())
  code      String   @unique // color code, e.g. "gelb"
  name      String   // display name, e.g. "Gelb"
  createdAt DateTime @default(now())
}

model Team {
  id         String  @id @default(cuid())
  name       String  @unique
  shortName  String  // e.g. "GER"
  group      String? // "A" to "L"
  flagEmoji  String  // e.g. "🇩🇪"
  externalId Int?    @unique // football-data.org team id

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
  tournamentWinnerTips TournamentWinnerTip[]
}

model Match {
  id          String      @id @default(cuid())
  matchNumber Int?        // seed bracket number (1-104); null for API-sourced matches
  externalId  Int?        @unique // football-data.org match id
  phase       String
  group       String?     // for group stage: "A"-"L"
  round       String?     // for KO: "R32", "R16", "QF", "SF", "F"
  homeTeamId  String?
  awayTeamId  String?
  homeTeam    Team?       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team?       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  kickoff     DateTime
  homeGoals   Int?
  awayGoals   Int?
  status      String      @default("UPCOMING")
  venue       String

  tips Tip[]
}

model SyncState {
  id         String    @id @default("main")
  lastSyncAt DateTime?
  lastStatus String?
  updatedAt  DateTime  @updatedAt
}

model Tip {
  id         String   @id @default(cuid())
  userId     String
  matchId    String
  homeGoals  Int
  awayGoals  Int
  points     Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
}

model TournamentWinnerTip {
  id     String @id @default(cuid())
  userId String @unique
  teamId String
  points Int?

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])
}

