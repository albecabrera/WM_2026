generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  name      String
  classCode String   // e.g. "6a", "5b"
  loginCode String   @unique // e.g. "mueller6a"
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())

  tips              Tip[]
  tournamentWinnerTip TournamentWinnerTip?

  @@index([classCode])
}

model Class {
  id        String   @id @default(cuid())
  code      String   @unique // e.g. "6a"
  name      String   // e.g. "Klasse 6a"
  teacherCode String @unique // teacher login code
  createdAt DateTime @default(now())
}

model Team {
  id        String  @id @default(cuid())
  name      String  @unique
  shortName String  // e.g. "GER"
  group     String? // "A" to "L"
  flagEmoji String  // e.g. "🇩🇪"

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
  tournamentWinnerTips TournamentWinnerTip[]
}

model Match {
  id          String      @id @default(cuid())
  matchNumber Int         @unique
  phase       MatchPhase
  group       String?     // for group stage: "A"-"L"
  round       String?     // for KO: "R32", "R16", "QF", "SF", "F"
  homeTeamId  String?
  awayTeamId  String?
  homeTeam    Team?       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team?       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  kickoff     DateTime
  homeGoals   Int?
  awayGoals   Int?
  status      MatchStatus @default(UPCOMING)
  venue       String

  tips Tip[]
}

model Tip {
  id         String   @id @default(cuid())
  userId     String
  matchId    String
  homeGoals  Int
  awayGoals  Int
  points     Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
}

model TournamentWinnerTip {
  id     String @id @default(cuid())
  userId String @unique
  teamId String
  points Int?

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum MatchPhase {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  FINAL
}

enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
}
